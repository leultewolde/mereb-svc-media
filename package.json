    "@fastify/sensible": "^6.0.4",
    "@mereb/shared-packages": "^0.0.39",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "9.39.1",
    "@types/node": "^20.19.33",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "9.39.1",
    "prisma": "^5.22.0",
